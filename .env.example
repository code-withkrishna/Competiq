# ── Required ──────────────────────────────────────────────────────────────────
# Anakin Wire API key — get yours at https://anakin.io/dashboard
ANAKIN_API_KEY=ask_xxxxxxxxxxxxxxxxxxxx

# Groq API key (FREE tier) — get yours at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Optional: AI Model ────────────────────────────────────────────────────────
# Default: llama-3.3-70b-versatile  (recommended — fastest on Groq free tier)
# GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Optional: Wire API Base URL ───────────────────────────────────────────────
# Only needed if Anakin changes their endpoint. Leave unset to use the default.
# ANAKIN_WIRE_BASE_URL=https://api.anakin.io/v1/wire

# ── Optional: Battle Mode Timeouts ───────────────────────────────────────────
# Fine-tune these if Battle Mode is timing out on slow networks.
# BATTLE_WIRE_TIMEOUT_MS=42000
# BATTLE_POLL_INTERVAL_MS=1500
# BATTLE_GROQ_TIMEOUT_MS=14000

# ── Optional: Wire Test Endpoint ─────────────────────────────────────────────
# Enables the /api/wire-test diagnostic endpoint. Without this, that route
# returns 404 (intentional — it is hidden in production unless you set this).
# Generate any random string, e.g.: openssl rand -hex 16
# WIRE_TEST_TOKEN=your_secret_test_token_here
